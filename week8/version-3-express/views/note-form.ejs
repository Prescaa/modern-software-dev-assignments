<%-
  include("layout", {
    pageTitle,
    categories,
    selectedCategoryId: null,
    body: `
      <div class="rounded-2xl bg-slate-900/80 border border-slate-800/80 px-5 py-5 max-w-2xl">
        <div class="flex items-start justify-between gap-4 mb-4">
          <div>
            <h1 class="text-base font-semibold text-slate-50">${note ? 'Edit Note' : 'New Note'}</h1>
            <p class="text-[11px] text-slate-500">
              Capture dev thoughts. Use <code>TODO:</code> or <code>!</code> to turn text into action items.
            </p>
          </div>
        </div>

        ${
          error
            ? `<div class="mb-4 rounded-xl border border-red-900 bg-red-950/50 px-3 py-2 text-[11px] text-red-300">
                 ${error}
               </div>`
            : ""
        }

        <form method="POST" action="${note ? `/notes/update/${note.id}` : '/notes'}" class="space-y-4">
          <div class="space-y-1">
            <label class="text-xs font-medium text-slate-300">Title</label>
            <input
              type="text"
              name="title"
              value="${(note && note.title) || (form && form.title) || ''}"
              class="w-full rounded-xl border border-slate-700/80 bg-slate-950/60 px-3 py-2 text-sm text-slate-50 placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-sky-500/80 focus:border-sky-500/40"
              placeholder="Sprint planning notes"
              required
            />
          </div>

          <div class="space-y-1">
            <label class="text-xs font-medium text-slate-300">Category</label>
            <select
              name="category_id"
              class="w-full rounded-xl border border-slate-700/80 bg-slate-950/60 px-3 py-2 text-sm text-slate-50 focus:outline-none focus:ring-2 focus:ring-sky-500/80 focus:border-sky-500/40"
            >
              <option value="">Uncategorised</option>
              ${
                categories && categories.length
                  ? categories
                      .map((cat) => {
                        const selected =
                          (note && String(note.category_id) === String(cat.id)) ||
                          (form && String(form.category_id) === String(cat.id))
                            ? "selected"
                            : "";
                        return `<option value="${cat.id}" ${selected}>${cat.name}</option>`;
                      })
                      .join("")
                  : ""
              }
            </select>
          </div>

          <div class="space-y-1">
            <label class="text-xs font-medium text-slate-300">Content</label>
            <textarea
              name="content"
              rows="10"
              class="w-full rounded-xl border border-slate-700/80 bg-slate-950/60 px-3 py-2 text-sm text-slate-50 placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-sky-500/80 focus:border-sky-500/40 font-mono"
              placeholder="TODO: Refactor legacy auth flow&#10;Deploy to staging!&#10;Capture any ideas, notes, or follow-ups here."
              required
            >${(note && note.content) || (form && form.content) || ''}</textarea>
          </div>

          <div class="flex items-center justify-between pt-2">
            <a
              href="/"
              class="text-[11px] text-slate-400 hover:text-slate-200 transition"
            >
              Back to dashboard
            </a>
            <button
              type="submit"
              class="inline-flex items-center gap-1.5 rounded-lg bg-sky-500 px-4 py-1.5 text-xs font-medium text-white shadow-sm shadow-sky-500/40 hover:bg-sky-400 transition"
            >
              ${note ? 'Update Note' : 'Save Note'}
            </button>
          </div>
        </form>
      </div>
    `,
  })
%>

