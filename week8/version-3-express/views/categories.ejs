<%-
  include("layout", {
    pageTitle,
    categories,
    selectedCategoryId: null,
    body: `
      <div class="grid grid-cols-[minmax(0,3fr)_minmax(0,2fr)] gap-4 max-w-5xl">
        <section class="rounded-2xl bg-slate-900/80 border border-slate-800/80 px-5 py-5">
          <div class="flex items-start justify-between gap-4 mb-4">
            <div>
              <h1 class="text-base font-semibold text-slate-50">
                Categories
              </h1>
              <p class="text-[11px] text-slate-500">
                Organise notes by focus area, project, or context.
              </p>
            </div>
          </div>

          ${
            error
              ? `<div class="mb-4 rounded-xl border border-red-900 bg-red-950/50 px-3 py-2 text-[11px] text-red-300">
                   ${error}
                 </div>`
              : ""
          }

          <form method="POST" action="/categories" class="space-y-3 mb-4">
            <div class="space-y-1">
              <label class="text-xs font-medium text-slate-300">Name</label>
              <input
                type="text"
                name="name"
                class="w-full rounded-xl border border-slate-700/80 bg-slate-950/60 px-3 py-2 text-sm text-slate-50 placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-sky-500/80 focus:border-sky-500/40"
                placeholder="Architecture, Release, Experiments"
                required
              />
            </div>

            <div class="space-y-1">
              <label class="text-xs font-medium text-slate-300">Accent Colour</label>
              <input
                type="color"
                name="color"
                value="#38bdf8"
                class="h-9 w-20 rounded-lg border border-slate-700/80 bg-slate-950/60"
              />
            </div>

            <div class="flex justify-end">
              <button
                type="submit"
                class="inline-flex items-center gap-1.5 rounded-lg bg-sky-500 px-4 py-1.5 text-xs font-medium text-white shadow-sm shadow-sky-500/40 hover:bg-sky-400 transition"
              >
                Add Category
              </button>
            </div>
          </form>

          <div class="border-t border-slate-800/80 pt-4">
            ${
              categories && categories.length
                ? `<ul class="space-y-2 text-sm">
                    ${categories
                      .map(
                        (cat) =>
                          `<li class="flex items-center justify-between gap-3 rounded-xl bg-slate-950/60 border border-slate-800/80 px-3 py-2">
                            <div class="flex items-center gap-2">
                              <span class="h-2.5 w-2.5 rounded-full" style="background-color: ${cat.color};"></span>
                              <span class="text-slate-100">${cat.name}</span>
                            </div>
                            <form method="POST" action="/categories/${cat.id}/delete">
                              <button
                                type="submit"
                                class="text-[11px] text-slate-500 hover:text-red-400 hover:bg-red-950/40 border border-transparent hover:border-red-900 rounded-lg px-2 py-1 transition"
                              >
                                Delete
                              </button>
                            </form>
                          </li>`
                      )
                      .join("")}
                  </ul>`
                : `<p class="text-[12px] text-slate-500">
                    No categories yet. Create one to start grouping your notes.
                  </p>`
            }
          </div>
        </section>

        <aside class="space-y-4">
          <div class="rounded-2xl bg-slate-900/80 border border-slate-800/80 px-4 py-4">
            <h2 class="text-sm font-semibold text-slate-50 mb-1">
              Tips
            </h2>
            <ul class="space-y-1.5 text-[12px] text-slate-300">
              <li>Use categories like <em>Architecture</em>, <em>Frontend</em>, <em>Backend</em>, <em>Release</em>.</li>
              <li>Combine with <code>TODO:</code> and <code>!</code> markers inside notes to drive your action items.</li>
            </ul>
          </div>

          <a
            href="/"
            class="inline-flex items-center justify-center rounded-xl border border-slate-800/80 bg-slate-950/60 px-3 py-2 text-[11px] font-medium text-slate-300 hover:bg-slate-900/80 hover:text-slate-50 transition w-full"
          >
            Back to dashboard
          </a>
        </aside>
      </div>
    `,
  })
%>

