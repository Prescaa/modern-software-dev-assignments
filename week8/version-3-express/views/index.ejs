<%-
  include("layout", {
    pageTitle,
    categories,
    selectedCategoryId,
    body: `
      <div class="flex flex-col gap-4">
        <div class="grid grid-cols-3 gap-4">
          <div class="rounded-2xl bg-slate-900/80 border border-slate-800/80 px-4 py-3">
            <p class="text-[11px] uppercase tracking-wide text-slate-400">
              Notes
            </p>
            <p class="mt-1 text-2xl font-semibold text-slate-50">
              ${stats.totalNotes}
            </p>
          </div>
          <div class="rounded-2xl bg-slate-900/80 border border-slate-800/80 px-4 py-3">
            <p class="text-[11px] uppercase tracking-wide text-slate-400">
              Categories
            </p>
            <p class="mt-1 text-2xl font-semibold text-slate-50">
              ${stats.totalCategories}
            </p>
          </div>
          <div class="rounded-2xl bg-slate-900/80 border border-slate-800/80 px-4 py-3">
            <p class="text-[11px] uppercase tracking-wide text-slate-400">
              Action Items
            </p>
            <p class="mt-1 text-2xl font-semibold text-sky-400">
              ${stats.totalActionItems}
            </p>
          </div>
        </div>

        <div class="rounded-2xl bg-slate-900/80 border border-slate-800/80 overflow-hidden">
          <div class="px-4 py-3 border-b border-slate-800/80 flex items-center justify-between">
            <div>
              <h2 class="text-sm font-semibold text-slate-50">
                Notes
              </h2>
              <p class="text-[11px] text-slate-500">
                Filter by category using the sidebar.
              </p>
            </div>
            <a
              href="/notes/new"
              class="inline-flex items-center gap-1.5 rounded-lg bg-sky-500 px-3 py-1.5 text-xs font-medium text-white shadow-sm shadow-sky-500/40 hover:bg-sky-400 transition"
            >
              + New Note
            </a>
          </div>

          <div class="divide-y divide-slate-800/80">
            ${
              notes.length === 0
                ? `
                    <div class="px-4 py-6 text-sm text-slate-500">
                      No notes yet. Create one to get started.
                    </div>
                  `
                : notes
                    .map((note) => {
                      const chip = note.category_name
                        ? `<span class="inline-flex items-center gap-1 rounded-full border border-slate-700/80 px-2 py-0.5 text-[10px] text-slate-300">
                            <span class="h-2 w-2 rounded-full" style="background-color: ${note.category_color};"></span>
                            <span class="truncate max-w-[120px]">${note.category_name}</span>
                          </span>`
                        : `<span class="inline-flex items-center rounded-full border border-slate-700/80 px-2 py-0.5 text-[10px] text-slate-400">
                            Uncategorised
                          </span>`;

                      const preview =
                        (note.content || "")
                          .split(/\\r?\\n/)
                          .find((line) => line.trim().length > 0) || "";

                      const actionsPreview =
                        note.actionItems && note.actionItems.length
                          ? note.actionItems
                              .slice(0, 2)
                              .map((item) => `<li class="truncate">${item}</li>`)
                              .join("")
                          : "";

                      return `
                        <article class="px-4 py-3 hover:bg-slate-900/80 transition">
                          <div class="flex items-start justify-between gap-4">
                            <div class="space-y-1">
                              <a href="/notes/${note.id}" class="text-sm font-semibold text-slate-50 hover:text-sky-400 transition">
                                ${note.title}
                              </a>
                              <p class="text-[11px] text-slate-500">
                                ${preview}
                              </p>
                              <div class="flex items-center gap-2 mt-1">
                                ${chip}
                                ${
                                  note.actionItems && note.actionItems.length
                                    ? `<span class="inline-flex items-center gap-1 rounded-full bg-sky-500/10 px-2 py-0.5 text-[10px] text-sky-400">
                                        ${note.actionItems.length} action item${note.actionItems.length === 1 ? "" : "s"}
                                      </span>`
                                    : ""
                                }
                              </div>
                              ${
                                actionsPreview
                                  ? `<ul class="mt-2 space-y-0.5 text-[11px] text-slate-300">
                                      ${actionsPreview}
                                    </ul>`
                                  : ""
                              }
                            </div>
                            <div class="flex items-center gap-2">
                              <a
                                href="/notes/edit/${note.id}"
                                class="text-[11px] text-slate-500 hover:text-sky-400 hover:bg-sky-950/40 border border-transparent hover:border-sky-900 rounded-lg px-2 py-1 transition"
                              >
                                Edit
                              </a>
                              <form method="POST" action="/notes/${note.id}/delete">
                                <button
                                  type="submit"
                                  class="text-[11px] text-slate-500 hover:text-red-400 hover:bg-red-950/40 border border-transparent hover:border-red-900 rounded-lg px-2 py-1 transition"
                                >
                                  Delete
                                </button>
                              </form>
                            </div>
                          </div>
                        </article>
                      `;
                    })
                    .join("")
            }
          </div>
        </div>
      </div>
    `,
  })
%>

