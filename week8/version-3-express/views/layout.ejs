<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <title><%= pageTitle || "Developer Control Center" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: {
                soft: "#1d4ed8",
              },
            },
          },
        },
      };
    </script>
  </head>
  <body class="h-full bg-slate-950 text-slate-50">
    <div class="min-h-screen flex flex-col">
      <header class="border-b border-slate-800/80 bg-slate-950/80 backdrop-blur z-10">
        <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div
              class="h-9 w-9 rounded-xl bg-gradient-to-tr from-sky-500 to-indigo-500 flex items-center justify-center shadow-lg shadow-sky-500/30"
            >
              <span class="text-sm font-semibold text-slate-50">DC</span>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wide text-slate-400">
                Developer
              </p>
              <p class="font-semibold text-sm text-slate-50">
                Control Center
              </p>
            </div>
          </div>
          <nav class="flex items-center gap-4 text-xs font-medium text-slate-400">
            <a
              href="/"
              class="px-3 py-1.5 rounded-lg hover:bg-slate-900/80 hover:text-slate-100 transition"
            >
              Dashboard
            </a>
            <a
              href="/notes/new"
              class="px-3 py-1.5 rounded-lg hover:bg-slate-900/80 hover:text-slate-100 transition"
            >
              New Note
            </a>
            <a
              href="/categories"
              class="px-3 py-1.5 rounded-lg hover:bg-slate-900/80 hover:text-slate-100 transition"
            >
              Categories
            </a>
          </nav>
        </div>
      </header>

      <main class="flex-1">
        <div class="max-w-6xl mx-auto px-6 py-6 flex gap-6">
          <aside
            class="w-72 flex-shrink-0 flex flex-col p-5 gap-6 rounded-2xl bg-slate-900/60 border border-slate-800/70 shadow-xl shadow-slate-900/60"
          >
            <div class="space-y-2">
              <p
                class="text-xs font-medium text-slate-400 flex items-center gap-2 uppercase tracking-wide"
              >
                <span
                  class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-sky-500/20 text-sky-400 text-[11px]"
                >
                  ◈
                </span>
                Categories
              </p>
              <nav class="space-y-1">
                <a
                  href="/"
                  class="w-full flex items-center justify-between rounded-lg px-3 py-2 text-xs font-medium transition
                    <%= !selectedCategoryId ? 'bg-slate-800 text-slate-50' : 'text-slate-400 hover:bg-slate-900/60 hover:text-slate-100' %>"
                >
                  <span>All Notes</span>
                  <span class="text-[10px] uppercase tracking-wide">
                    Overview
                  </span>
                </a>

                <% if (categories && categories.length) { %>
                  <% categories.forEach(function(category) { %>
                    <a
                      href="/?category=<%= category.id %>"
                      class="w-full flex items-center gap-2 rounded-lg px-3 py-2 text-xs font-medium transition
                        <%= String(selectedCategoryId) === String(category.id) ? 'bg-slate-800 text-slate-50' : 'text-slate-400 hover:bg-slate-900/60 hover:text-slate-100' %>"
                    >
                      <span
                        class="h-2 w-2 rounded-full"
                        style="background-color: <%= category.color %>;"
                      ></span>
                      <span class="truncate"><%= category.name %></span>
                    </a>
                  <% }) %>
                <% } else { %>
                  <p class="text-[11px] text-slate-500">
                    No categories yet. Create one in the Categories tab.
                  </p>
                <% } %>
              </nav>
            </div>

            <div
              class="mt-auto pt-4 border-t border-slate-800/80 flex items-center justify-between text-[11px] text-slate-500"
            >
              <div class="flex items-center gap-1.5">
                <span class="h-4 w-4 rounded-md bg-slate-800 flex items-center justify-center text-[10px]">
                  !
                </span>
                <span>Use <code>TODO:</code> or <code>!</code> in notes to create action items.</span>
              </div>
            </div>
          </aside>

          <section class="flex-1 flex flex-col gap-4">
            <%- body %>
          </section>
        </div>
      </main>
    </div>
  </body>
</html>

